#!/usr/bin/env bash
# SessionStart hook for Primer plugin

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Check if Primer is enabled for this project
# If no .primer file exists, exit silently — don't inject anything
if [ ! -f ".primer" ]; then
  exit 0
fi

# Read navigator skill content
navigator_content=$(cat "${PLUGIN_ROOT}/skills/navigator/SKILL.md" 2>&1 || echo "Error reading navigator skill")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

navigator_escaped=$(escape_for_json "$navigator_content")
session_context="<IMPORTANT>\nYou have the Primer plugin installed.\n\n**Below is your navigator skill. Follow it at the start of every session:**\n\n${navigator_escaped}\n\nIf APP_INTENT.md or CODE_MAP.md do not exist in the project root, use the Skill tool to invoke primer:app-onboarding to set up Primer for this project.\n</IMPORTANT>"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$session_context"
fi

exit 0
